[Unit]
Description=Next-Videos Video Downloader Service
After=network.target

[Service]
Type=simple
User=fida
WorkingDirectory=/var/www/web/Next-Videos/combined
ExecStart=/usr/bin/node server.js
Restart=on-failure
Environment=NODE_ENV=production
Environment=PORT=3001

[Install]
WantedBy=multi-user.target
